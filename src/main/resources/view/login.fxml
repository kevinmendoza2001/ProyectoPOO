<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.LoginController"
           prefHeight="550.0"
           prefWidth="480.0"
           styleClass="login-root">

    <VBox alignment="CENTER"
          spacing="15"
          prefWidth="350"
          prefHeight="355"
          maxWidth="350"
          maxHeight="355"
          styleClass="login-card">

        <padding>
            <Insets top="32" bottom="32" left="32" right="32"/>
        </padding>

        <Label text="RESTOBAR" styleClass="login-brand"/>
        <Label text="Sistema de gestión y ventas"
               styleClass="login-subtitle"/>

        <VBox spacing="6" prefWidth="286">
            <Label text="Usuario" styleClass="field-label"/>
            <TextField fx:id="txtUsuario"
                       promptText="Ingresa tu usuario"/>
        </VBox>

        <VBox spacing="6" prefWidth="286">
            <Label text="Contraseña" styleClass="field-label"/>
            <PasswordField fx:id="txtPassword"
                           promptText="Ingresa tu contraseña"/>
        </VBox>

        <Button fx:id="btnIngresar"
                text="Iniciar sesión"
                onAction="#onIngresar"
                styleClass="login-button"
                maxWidth="Infinity"/>

        <Label fx:id="lblMensaje"
               styleClass="login-error"
               wrapText="true"
               maxWidth="286"/>
    </VBox>
</StackPane>