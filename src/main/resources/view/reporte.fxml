<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ReporteController"
      spacing="15">

    <Label text="Reportes" styleClass="login-title"/>

    <VBox spacing="14" maxWidth="400" styleClass="login-card">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <GridPane hgap="10" vgap="12">
            <Label text="Total de productos:" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="lblTotalProductos" styleClass="login-title" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Total de usuarios:" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="lblTotalUsuarios" styleClass="login-title" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Valor del inventario:" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="lblValorInventario" styleClass="login-title" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Productos con stock bajo (&lt;5):" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label fx:id="lblStockBajo" styleClass="login-title" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <Button fx:id="btnDescargar" text="Descargar reporte (CSV)" onAction="#onDescargar" styleClass="login-button" maxWidth="Infinity"/>
    </VBox>
</VBox>